  "facts": {
    "fact_0001": {
      "fact_id": "fact_0001",
      "statement": "Retinoids regulate gene transcription by binding to RAR and RXR nuclear receptors.",
      "entity_id": "retinoids",
      "evidence_level": "A",
      "path": "facts/fact_0001.json"
    },
    "fact_0002": {
      "fact_id": "fact_0002",
      "statement": "Tretinoin binds directly to nuclear retinoic acid receptors (RARs) without metabolic conversion.",
      "entity_id": "tretinoin",
      "evidence_level": "A",
      "path": "facts/fact_0002.json"
    },
    "fact_0003": {
      "fact_id": "fact_0003",
      "statement": "Retinol undergoes a two-step enzymatic oxidation to become active all-trans retinoic acid.",
      "entity_id": "retinol",
      "evidence_level": "A",
      "path": "facts/fact_0003.json"
    },
    "fact_0004": {
      "fact_id": "fact_0004",
      "statement": "Retinol stimulates collagen synthesis and inhibits matrix metalloproteinases (MMPs) to reduce dermal degradation.",
      "entity_id": "retinol",
      "evidence_level": "A",
      "path": "facts/fact_0004.json"
    },
    "fact_0005": {
      "fact_id": "fact_0005",
      "statement": "Tretinoin is the gold standard for clinical improvement of photoaged skin.",
      "entity_id": "tretinoin",
      "evidence_level": "A",
      "path": "facts/fact_0005.json"
    },
    "fact_0006": {
      "fact_id": "fact_0006",
      "statement": "Tretinoin normalizes keratinocyte differentiation to prevent follicular occlusion in acne vulgaris.",
      "entity_id": "tretinoin",
      "evidence_level": "A",
      "path": "facts/fact_0006.json"
    },
    "fact_0007": {
      "fact_id": "fact_0007",
      "statement": "Adapalene selectively binds to retinoic acid receptors RAR-beta and RAR-gamma.",
      "entity_id": "adapalene",
      "evidence_level": "A",
      "path": "facts/fact_0007.json"
    },
    "fact_0008": {
      "fact_id": "fact_0008",
      "statement": "Adapalene exhibits lower irritation potential and superior photostability compared to tretinoin.",
      "entity_id": "adapalene",
      "evidence_level": "A",
      "path": "facts/fact_0008.json"
    },
    "fact_0009": {
      "fact_id": "fact_0009",
      "statement": "Tazarotene selectively binds to nuclear retinoic acid receptors RAR-beta and RAR-gamma.",
      "entity_id": "tazarotene",
      "evidence_level": "A",
      "path": "facts/fact_0009.json"
    },
    "fact_0010": {
      "fact_id": "fact_0010",
      "statement": "Tazarotene 0.1% cream is effective for treating facial photodamage, including fine wrinkles and hyperpigmentation.",
      "entity_id": "tazarotene",
      "evidence_level": "A",
      "path": "facts/fact_0010.json"
    },
    "fact_0011": {
      "fact_id": "fact_0011",
      "statement": "Retinaldehyde requires only a single metabolic conversion step to active retinoic acid in keratinocytes.",
      "entity_id": "retinaldehyde",
      "evidence_level": "A",
      "path": "facts/fact_0011.json"
    },
    "fact_0012": {
      "fact_id": "fact_0012",
      "statement": "Topical retinaldehyde improves skin hydration, elasticity, and reduces wrinkle depth.",
      "entity_id": "retinaldehyde",
      "evidence_level": "A",
      "path": "facts/fact_0012.json"
    },
    "fact_0013": {
      "fact_id": "fact_0013",
      "statement": "Retinyl palmitate is a stable retinoid ester requiring three conversion steps, making it less potent but gentler.",
      "entity_id": "retinyl_palmitate",
      "evidence_level": "B",
      "path": "facts/fact_0013.json"
    },
    "fact_0014": {
      "fact_id": "fact_0014",
      "statement": "Retinyl palmitate nano-formulation reduces inflammatory and non-inflammatory lesions in mild acne.",
      "entity_id": "retinyl_palmitate",
      "evidence_level": "A",
      "path": "facts/fact_0014.json"
    },
    "fact_0015": {
      "fact_id": "fact_0015",
      "statement": "Topical retinoids are contraindicated during pregnancy due to potential teratogenic risks.",
