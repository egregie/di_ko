{
  "version": "1.1",
  "entity_types": [
    "Ingredient", "Active", "Drug", "Disease", "Condition", "Procedure",
    "Device", "AnatomicalStructure", "Protocol", "Study", "Source",
    "Concept", "Fact", "Image", "Diagram", "Presentation", "Slide",
    "Layout", "Template",
    "procedure", "clinical_condition", "contraindication_context"
  ],
  "relationship_types": [
    "is_a", "belongs_to", "part_of", "contains", "treats", "causes",
    "used_for", "contraindicated_for", "interacts_with", "supports",
    "contradicts", "references", "derived_from", "has_evidence", "related_to"
  ],
  "evidence_levels": {
    "A": "systematic review / meta-analysis / RCT",
    "B": "cohort / clinical guideline",
    "C": "expert consensus / case series",
    "D": "anecdotal / blog — rejected for clinical slides"
  },
  "source_tiers": {
    "A": ["PubMed","Cochrane","NIH","FDA","EMA","peer-reviewed journals"],
    "B": ["Wikipedia","Britannica","textbooks","INCI/CosIng","manufacturer docs"],
    "C": ["Reddit","professional forums","industry communities"],
    "D": ["general blogs / SEO — context only, never a fact source"]
  },
  "entity_type_schemas": {
    "procedure": {
      "comment": "In-office/clinical procedure (Phase 8.7b). Not a molecule: has no PubChem CID or RDKit SVG; its visual route is anatomical/mechanism diagrams (Servier CC-BY-4.0 or source-grounded SVG), never prompt-generated.",
      "required": ["entity_id", "entity_type", "title", "mechanism", "indication", "evidence_level"],
      "forbidden": ["pubchem_cid", "molecule_svg"],
      "evidence_level_enum": ["strong", "moderate", "limited"],
      "indication_values": ["atrophic_scars", "rolling_scars", "boxcar_scars", "ice_pick_scars", "PIE", "PIH"]
    }
  },
  "p011_scope": {
    "comment": "P011 (deck-ready topic needs >=8 verified facts) applies ONLY to topical_active and procedure topics. clinical_condition and contraindication_context are auxiliary node-types (antecedent conditions, contraindication contexts) and are NOT subject to the >=8 threshold.",
    "p011_applies_to": ["topical_active", "procedure"],
    "p011_exempt": ["clinical_condition", "contraindication_context"]
  }
}
